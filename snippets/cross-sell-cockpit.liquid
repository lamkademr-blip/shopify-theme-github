{% comment %}
  Cross-sell section "Complétez votre cockpit" — displays accessory products on steering wheel pages.
  Uses Shopify's product recommendations API with "related" intent.
{% endcomment %}

{%- if request.page_type == 'product' and product.type contains 'Volant' or product.collections | map: 'handle' | join: ',' | contains: 'volant' -%}
<style>
  .cross-sell-cockpit {
    margin-top: 24px;
    padding: 20px;
    background: rgba(var(--color-foreground), 0.02);
    border: 1px solid rgba(var(--color-foreground), 0.06);
    border-radius: 8px;
  }
  .cross-sell-cockpit__title {
    font-size: 16px;
    font-weight: 600;
    color: rgb(var(--color-foreground));
    margin: 0 0 16px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .cross-sell-cockpit__title svg {
    width: 20px;
    height: 20px;
    color: #c9a96e;
  }
  .cross-sell-cockpit__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
  .cross-sell-card {
    display: flex;
    flex-direction: column;
    background: rgb(var(--color-background));
    border: 1px solid rgba(var(--color-foreground), 0.08);
    border-radius: 6px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s;
  }
  .cross-sell-card:hover {
    border-color: #c9a96e;
  }
  .cross-sell-card__img {
    aspect-ratio: 1;
    overflow: hidden;
    background: rgba(var(--color-foreground), 0.03);
  }
  .cross-sell-card__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .cross-sell-card__info {
    padding: 10px;
  }
  .cross-sell-card__name {
    font-size: 12px;
    font-weight: 500;
    line-height: 1.3;
    margin: 0 0 4px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .cross-sell-card__price {
    font-size: 13px;
    font-weight: 600;
    color: rgb(var(--color-foreground));
    margin: 0;
  }
  .cross-sell-card__price s {
    font-size: 11px;
    font-weight: 400;
    color: rgba(var(--color-foreground), 0.5);
    margin-left: 4px;
  }
  .cross-sell-card__add {
    display: block;
    width: 100%;
    padding: 8px;
    background: transparent;
    border: none;
    border-top: 1px solid rgba(var(--color-foreground), 0.06);
    color: #c9a96e;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: background 0.2s;
    min-height: 44px;
    text-align: center;
  }
  .cross-sell-card__add:hover {
    background: rgba(201, 169, 110, 0.08);
  }
  @media screen and (max-width: 749px) {
    .cross-sell-cockpit { padding: 16px; margin-top: 20px; }
    .cross-sell-cockpit__title { font-size: 14px; }
    .cross-sell-card__info { padding: 8px; }
  }
</style>

<div class="cross-sell-cockpit" id="CrossSellCockpit" style="display:none">
  <h3 class="cross-sell-cockpit__title">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v8"/><path d="M8 12h8"/></svg>
    Complétez votre cockpit
  </h3>
  <div class="cross-sell-cockpit__grid" id="CrossSellGrid"></div>
</div>

<script>
(function() {
  var container = document.getElementById('CrossSellCockpit');
  var grid = document.getElementById('CrossSellGrid');
  if (!container || !grid) return;

  fetch('{{ routes.product_recommendations_url }}?product_id={{ product.id }}&limit=4&intent=related&section_id=cross-sell-fetch')
    .then(function(r) { return r.text(); })
    .then(function(html) {
      var parser = new DOMParser();
      var doc = parser.parseFromString(html, 'text/html');
      var products = doc.querySelectorAll('[data-cross-sell-product]');
      if (products.length === 0) {
        var items = doc.querySelectorAll('.product-card, .card-wrapper, [class*="card-product"], .grid__item');
        if (items.length === 0) return;
      }

      fetch('/recommendations/products.json?product_id={{ product.id }}&limit=4&intent=related')
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (!data.products || data.products.length === 0) return;

          var accessories = data.products.filter(function(p) {
            var t = (p.product_type || '').toLowerCase();
            var title = (p.title || '').toLowerCase();
            return t !== 'volant' && !title.includes('volant');
          });

          var toShow = accessories.length >= 2 ? accessories : data.products;
          toShow = toShow.slice(0, 4);
          if (toShow.length === 0) return;

          var html = '';
          toShow.forEach(function(p) {
            var img = p.featured_image || (p.images && p.images[0]) || '';
            var price = (p.price / 100).toFixed(2).replace('.', ',') + ' €';
            var comparePrice = '';
            if (p.compare_at_price && p.compare_at_price > p.price) {
              comparePrice = '<s>' + (p.compare_at_price / 100).toFixed(2).replace('.', ',') + ' €</s>';
            }
            var variantId = p.variants && p.variants[0] ? p.variants[0].id : '';

            html += '<div class="cross-sell-card">' +
              '<a href="' + p.url + '" class="cross-sell-card__img">' +
                (img ? '<img src="' + img + '" alt="' + (p.title || '').replace(/"/g, '&quot;') + '" loading="lazy" width="200" height="200">' : '') +
              '</a>' +
              '<div class="cross-sell-card__info">' +
                '<p class="cross-sell-card__name"><a href="' + p.url + '" style="text-decoration:none;color:inherit">' + p.title + '</a></p>' +
                '<p class="cross-sell-card__price">' + price + ' ' + comparePrice + '</p>' +
              '</div>' +
              '<button class="cross-sell-card__add" data-variant-id="' + variantId + '">+ Ajouter</button>' +
            '</div>';
          });

          grid.innerHTML = html;
          container.style.display = 'block';

          grid.querySelectorAll('.cross-sell-card__add').forEach(function(btn) {
            btn.addEventListener('click', function(e) {
              e.preventDefault();
              var vid = this.getAttribute('data-variant-id');
              if (!vid) return;
              this.textContent = '...';
              this.disabled = true;
              fetch('/cart/add.js', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id: parseInt(vid), quantity: 1 })
              })
              .then(function(r) { return r.json(); })
              .then(function() {
                btn.textContent = 'Ajouté !';
                setTimeout(function() {
                  btn.textContent = '+ Ajouter';
                  btn.disabled = false;
                }, 2000);
              })
              .catch(function() {
                btn.textContent = 'Erreur';
                setTimeout(function() {
                  btn.textContent = '+ Ajouter';
                  btn.disabled = false;
                }, 2000);
              });
            });
          });
        });
    });
})();
</script>
{%- endif -%}
