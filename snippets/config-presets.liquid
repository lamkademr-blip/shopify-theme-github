{% comment %}
  CRO P1 — Presets de configuration + nettoyage des libelles YMQ.
  - 3 cartes preset inserees au-dessus du configurateur : Essentiel / Sport / Premium.
    Un clic coche automatiquement les options YMQ correspondantes (matching par texte,
    supplements calcules dynamiquement depuis les data-price des inputs).
  - Retire les prefixes numeriques techniques des titres d'options ("11.2 Choix du..." -> "Choix du...").
  N'apparait que si le produit a un vrai configurateur (8+ groupes YMQ).
{% endcomment %}

{%- if request.page_type == 'product' -%}
<style>
  .config-presets {
    margin: 0 0 16px;
    /* La rangee scrollable a une largeur min-content de ~470px (3 cartes) qui
       se propage aux parents YMQ et elargit toute la page sur mobile.
       contain: inline-size annule cette contribution ; max-width en fallback. */
    width: 100%;
    max-width: 100%;
    min-width: 0;
    contain: inline-size;
  }
  .config-presets__heading {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin: 0 0 10px;
    color: rgb(var(--color-foreground));
  }
  .config-presets__row {
    display: flex;
    gap: 10px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 4px;
  }
  .config-presets__row::-webkit-scrollbar { display: none; }
  .config-preset {
    flex: 1 0 150px;
    min-width: 150px;
    border: 1px solid rgba(var(--color-foreground), 0.15);
    background: rgb(var(--color-background));
    padding: 12px;
    text-align: left;
    cursor: pointer;
    transition: border-color 0.2s, box-shadow 0.2s;
    font-family: inherit;
  }
  .config-preset:hover { border-color: #c9a96e; }
  .config-preset.is-selected {
    border-color: #c9a96e;
    box-shadow: 0 0 0 1px #c9a96e;
  }
  .config-preset__tag {
    display: inline-block;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #c9a96e;
    margin-bottom: 6px;
  }
  .config-preset__name {
    font-size: 14px;
    font-weight: 700;
    margin: 0 0 4px;
    color: rgb(var(--color-foreground));
  }
  .config-preset__desc {
    font-size: 11px;
    line-height: 1.4;
    color: rgba(var(--color-foreground), 0.65);
    margin: 0 0 8px;
  }
  .config-preset__price {
    font-size: 12px;
    font-weight: 600;
    color: #c9a96e;
  }
  .config-presets__note {
    font-size: 10px;
    color: rgba(var(--color-foreground), 0.55);
    margin: 8px 0 0;
  }
</style>

<script>
(function() {
  var PRESETS = [
    {
      key: 'essentiel',
      name: 'Essentiel',
      tag: 'Le plus choisi',
      desc: 'La configuration classique, prete a commander telle quelle.',
      reset: true,
      selections: []
    },
    {
      key: 'sport',
      name: 'Sport',
      tag: 'Tendance',
      desc: 'Haut et bas en carbone forge noir.',
      selections: [
        // Selon le produit, le materiau est un choix direct (Golf : "Carbone
        // Forge Noir" dans la liste) ou une chaine (BMW : Carbone -> fibre
        // forgee -> couleur). Les alternatives couvrent les deux structures.
        { alts: [
          { group: /mat[eé]riau du haut/i, label: /carbone forg[eé].*noir/i },
          { group: /mat[eé]riau du haut/i, label: /^carbone$/i }
        ] },
        { optional: true, group: /style de fibre de carbone/i, label: /forg/i },
        { optional: true, group: /carbone forg[eé].*haut/i, label: /noir/i }
      ]
    },
    {
      key: 'premium',
      name: 'Premium',
      tag: 'Experience ultime',
      desc: 'Carbone forge noir + ShiftLEDs de performance.',
      selections: [
        { group: /shiftled/i, label: /^oui/i },
        { alts: [
          { group: /mat[eé]riau du haut/i, label: /carbone forg[eé].*noir/i },
          { group: /mat[eé]riau du haut/i, label: /^carbone$/i }
        ] },
        { optional: true, group: /style de fibre de carbone/i, label: /forg/i },
        { optional: true, group: /carbone forg[eé].*haut/i, label: /noir/i }
      ]
    }
  ];

  function track(event, params) {
    if (typeof window.configTrackPush === 'function') window.configTrackPush(event, params);
  }

  function formatEUR(v) {
    return v.toFixed(2).replace('.', ',') + ' €';
  }

  // --- Nettoyage des libelles : retire "11.2 " etc. des titres d'options ---
  // Le numero vit dans <span class="ymq_lable">11.2 Choix du...</span>
  function cleanLabels() {
    document.querySelectorAll('.ymq-option-title .ymq_lable').forEach(function(span) {
      for (var i = 0; i < span.childNodes.length; i++) {
        var node = span.childNodes[i];
        if (node.nodeType === 3 && /^\s*\d+(?:\.\s?\d+)*\.?\s+/.test(node.nodeValue)) {
          node.nodeValue = node.nodeValue.replace(/^\s*\d+(?:\.\s?\d+)*\.?\s+/, '');
          break;
        }
      }
    });
  }

  // --- Resolution d'un preset : trouve les inputs YMQ correspondants ---
  // includeHidden=true sert au calcul du prix affiche sur la carte (les
  // sous-options conditionnelles sont masquees tant que le parent n'est pas coche).
  function getBoxes(includeHidden) {
    var all = document.querySelectorAll('.ymq-options-box');
    if (includeHidden) return Array.prototype.slice.call(all);
    return Array.prototype.filter.call(all, function(b) { return b.offsetParent !== null; });
  }

  function inputLabel(input) {
    var lab = input.id ? document.querySelector('label[for="' + input.id + '"]') : null;
    if (lab) return lab.textContent.trim();
    var sib = input.nextElementSibling;
    return sib ? sib.textContent.trim() : '';
  }

  function findSelection(sel, includeHidden) {
    var alts = sel.alts || [sel];
    for (var a = 0; a < alts.length; a++) {
      var boxes = getBoxes(includeHidden);
      for (var i = 0; i < boxes.length; i++) {
        var title = boxes[i].querySelector('.ymq-option-title');
        if (!title || !alts[a].group.test(title.textContent)) continue;
        var inputs = boxes[i].querySelectorAll('input[type="radio"], input[type="checkbox"]');
        for (var j = 0; j < inputs.length; j++) {
          if (alts[a].label.test(inputLabel(inputs[j]))) return inputs[j];
        }
      }
    }
    return null;
  }

  // --- Snapshot de l'etat initial (pour le preset "Essentiel" = reset) ---
  function snapshotInitial() {
    document.querySelectorAll('.ymq-options-box input[type="radio"], .ymq-options-box input[type="checkbox"]').forEach(function(i) {
      if (!i.hasAttribute('data-cro-init')) {
        i.setAttribute('data-cro-init', i.checked ? '1' : '0');
      }
    });
  }

  function restoreSnapshot() {
    var all = document.querySelectorAll('.ymq-options-box input[type="radio"], .ymq-options-box input[type="checkbox"]');
    // Passe 1 : re-cocher ce qui etait coche au chargement (decoche les radios voisines)
    all.forEach(function(i) {
      if (i.getAttribute('data-cro-init') === '1' && !i.checked) i.click();
    });
    // Passe 2 : decocher ce qui ne l'etait pas et l'est reste
    all.forEach(function(i) {
      if (i.getAttribute('data-cro-init') === '1' || !i.checked) return;
      if (i.type === 'checkbox') {
        i.click();
      } else {
        i.checked = false;
        i.dispatchEvent(new Event('change', { bubbles: true }));
        i.dispatchEvent(new Event('input', { bubbles: true }));
      }
    });
  }

  // --- Remplissage des champs obligatoires restes sans reponse ---
  // Apres un preset, YMQ peut avoir des groupes requis non repondus (ex : "Ajouter
  // un couvercle d'airbag personnalise ?"). On coche l'option gratuite par defaut
  // (preference "Non") — jamais une option payante en silence.
  function fillRequiredDefaults() {
    var filled = 0;
    getBoxes(false).forEach(function(box) {
      var inputs = box.querySelectorAll('input[type="radio"], input[type="checkbox"]');
      if (!inputs.length) return;
      if (box.querySelector('input[type="radio"]:checked, input[type="checkbox"]:checked')) return;
      var unfilled = box.querySelector('input[name^="empty-properties"]');
      var required = box.querySelector('.ymq_lable.required');
      if (!unfilled && !required) return;
      var pick = null;
      for (var i = 0; i < inputs.length; i++) {
        var price = parseFloat(inputs[i].getAttribute('data-price')) || 0;
        if (price !== 0) continue;
        if (/^non\b/i.test(inputLabel(inputs[i]))) { pick = inputs[i]; break; }
        if (!pick) pick = inputs[i];
      }
      if (pick) { pick.click(); filled++; }
    });
    return filled;
  }

  function presetPrice(preset) {
    var total = 0;
    var foundAny = false;
    preset.selections.forEach(function(sel) {
      var input = findSelection(sel, true);
      if (input) {
        foundAny = true;
        total += parseFloat(input.getAttribute('data-price')) || 0;
      }
    });
    return { total: total, foundAny: foundAny };
  }

  // Application multi-passes : cocher un parent revele des sous-options YMQ,
  // donc on re-cherche les selections restantes apres chaque vague de clics.
  function applyPreset(preset, card, bar) {
    bar.querySelectorAll('.config-preset').forEach(function(c) { c.classList.remove('is-selected'); });
    card.classList.add('is-selected');

    function refreshPrice() {
      if (typeof window.updateStickyPrice === 'function') {
        setTimeout(window.updateStickyPrice, 300);
        setTimeout(window.updateStickyPrice, 800);
      }
      setTimeout(cleanLabels, 400);
    }

    // Preset "Essentiel" : retour a la configuration d'origine de la page
    if (preset.reset) {
      restoreSnapshot();
      setTimeout(restoreSnapshot, 500);
      track('config_preset_apply', { preset: preset.key, preset_reset: true });
      setTimeout(refreshPrice, 600);
      return;
    }

    var remaining = preset.selections.slice();
    var applied = 0;
    var autofilled = 0;
    var passes = 0;

    function pass() {
      passes++;
      var next = [];
      remaining.forEach(function(sel) {
        var input = findSelection(sel, false);
        if (input) {
          if (!input.checked) input.click();
          applied++;
        } else {
          next.push(sel);
        }
      });
      remaining = next;
      autofilled += fillRequiredDefaults();
      if (remaining.length > 0 && passes < 5) {
        setTimeout(pass, 500);
      } else {
        // Derniere verification des obligatoires apres stabilisation de YMQ
        setTimeout(function() {
          autofilled += fillRequiredDefaults();
          var missing = remaining.filter(function(s) { return !s.optional; }).length;
          track('config_preset_apply', {
            preset: preset.key,
            preset_options_applied: applied,
            preset_options_missing: missing,
            preset_required_autofilled: autofilled
          });
          refreshPrice();
        }, 600);
      }
    }

    pass();
  }

  // --- Construction de la barre de presets ---
  function buildBar() {
    var bar = document.createElement('div');
    bar.className = 'config-presets';
    bar.id = 'ConfigPresets';

    var heading = document.createElement('p');
    heading.className = 'config-presets__heading';
    heading.textContent = 'Configurations recommandees';
    bar.appendChild(heading);

    var row = document.createElement('div');
    row.className = 'config-presets__row';
    bar.appendChild(row);

    PRESETS.forEach(function(preset) {
      var priced = presetPrice(preset);
      // Ne pas afficher un preset dont aucune option n'existe sur ce produit
      if (preset.selections.length > 0 && !priced.foundAny) return;

      var card = document.createElement('button');
      card.type = 'button';
      card.className = 'config-preset';
      card.setAttribute('data-preset', preset.key);

      var tag = document.createElement('span');
      tag.className = 'config-preset__tag';
      tag.textContent = preset.tag;
      card.appendChild(tag);

      var name = document.createElement('p');
      name.className = 'config-preset__name';
      name.textContent = preset.name;
      card.appendChild(name);

      var desc = document.createElement('p');
      desc.className = 'config-preset__desc';
      desc.textContent = preset.desc;
      card.appendChild(desc);

      var price = document.createElement('span');
      price.className = 'config-preset__price';
      price.textContent = priced.total > 0 ? '+ ' + formatEUR(priced.total) : 'Sans supplement';
      card.appendChild(price);

      card.addEventListener('click', function() { applyPreset(preset, card, bar); });
      row.appendChild(card);
    });

    var note = document.createElement('p');
    note.className = 'config-presets__note';
    note.textContent = 'Un point de depart : chaque option reste modifiable ci-dessous.';
    bar.appendChild(note);

    return bar;
  }

  // --- Insertion une fois YMQ charge ---
  var attempts = 0;
  function init() {
    var boxes = document.querySelectorAll('.ymq-options-box');
    if (boxes.length === 0) {
      if (++attempts < 30) setTimeout(init, 500);
      return;
    }
    cleanLabels();
    snapshotInitial();
    // YMQ peut injecter des inputs apres coup : completer le snapshot
    setTimeout(snapshotInitial, 2000);
    // Presets uniquement sur les vrais configurateurs (volants)
    if (boxes.length >= 8 && !document.getElementById('ConfigPresets')) {
      var first = boxes[0];
      var bar = buildBar();
      if (bar.querySelectorAll('.config-preset').length > 1) {
        first.parentNode.insertBefore(bar, first);
      }
    }
    // YMQ reecrit les titres apres selection : re-nettoyer apres chaque interaction
    document.addEventListener('click', function(e) {
      if (e.target.closest && e.target.closest('[class*="ymq"]')) {
        setTimeout(cleanLabels, 200);
        setTimeout(cleanLabels, 600);
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>
{%- endif -%}
