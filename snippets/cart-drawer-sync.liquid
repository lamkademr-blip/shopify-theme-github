{% comment %}
  Fix : YMQ ajoute au panier via son propre AJAX (XHR) et court-circuite le
  rendu du theme — le tiroir panier restait sur "0,00 €" jusqu'au rechargement.
  Approche robuste : au clic sur un bouton d'ajout, on surveille /cart.js ;
  des que le panier change reellement, on re-rend les sections cart-drawer et
  cart-icon-bubble (Section Rendering API) et on ouvre le tiroir.
  Pas de patch fetch/XHR : les scripts tiers ne peuvent pas le neutraliser.
{% endcomment %}
<script>
(function () {
  'use strict';

  var polling = false;
  var root = (window.Shopify && Shopify.routes && Shopify.routes.root) || '/';

  function cartState() {
    return fetch(root + 'cart.js?_t=' + Date.now(), { cache: 'no-store' }).then(function (r) { return r.json(); })
      .then(function (c) { return c.item_count + '|' + c.total_price; });
  }

  function swapSection(wrapperId, html) {
    var wrapper = document.getElementById(wrapperId);
    if (!wrapper || !html) return false;
    var tmp = document.createElement('div');
    tmp.innerHTML = html;
    var fresh = tmp.firstElementChild;
    if (!fresh) return false;
    wrapper.innerHTML = fresh.innerHTML;
    return true;
  }

  function refreshDrawer() {
    fetch(root + '?sections=cart-drawer,cart-icon-bubble&_t=' + Date.now(), { cache: 'no-store' })
      .then(function (r) { return r.json(); })
      .then(function (sections) {
        swapSection('shopify-section-cart-drawer', sections['cart-drawer']);
        if (!swapSection('shopify-section-cart-icon-bubble', sections['cart-icon-bubble'])) {
          // Dawn rend la bulle dans un element #cart-icon-bubble sans wrapper de section
          var bubble = document.getElementById('cart-icon-bubble');
          if (bubble && sections['cart-icon-bubble']) {
            var t = document.createElement('div');
            t.innerHTML = sections['cart-icon-bubble'];
            var freshB = t.firstElementChild;
            if (freshB) bubble.innerHTML = freshB.innerHTML;
          }
        }
        var drawer = document.querySelector('cart-drawer');
        if (drawer) {
          drawer.classList.remove('is-empty');
          if (typeof drawer.open === 'function') drawer.open();
        }
      })
      .catch(function () {});
  }

  function watchForCartChange() {
    if (polling) return;
    polling = true;
    cartState().then(function (base) {
      var tries = 0;
      var iv = setInterval(function () {
        tries++;
        cartState().then(function (now) {
          if (now !== base) {
            clearInterval(iv);
            polling = false;
            refreshDrawer();
          } else if (tries >= 15) {
            clearInterval(iv);
            polling = false;
          }
        }).catch(function () {
          if (tries >= 15) { clearInterval(iv); polling = false; }
        });
      }, 600);
    }).catch(function () { polling = false; });
  }

  document.addEventListener('click', function (e) {
    if (e.target.closest && e.target.closest('button[name="add"], #StickyATCBtn, .quick-add__submit')) {
      watchForCartChange();
    }
  }, true);
})();
</script>
