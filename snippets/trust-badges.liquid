{% comment %}
  Trust badges / reassurance block — rendered below the buy-buttons on product pages.
{% endcomment %}

<style>
  .trust-badges {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    margin-top: 16px;
    padding: 16px;
    background: rgba(var(--color-foreground), 0.03);
    border: 1px solid rgba(var(--color-foreground), 0.06);
    border-radius: 8px;
  }
  .trust-badge {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 0;
  }
  .trust-badge__icon {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .trust-badge__icon svg {
    width: 20px;
    height: 20px;
    color: #c9a96e;
  }
  .trust-badge__text {
    font-size: 12px;
    font-weight: 500;
    line-height: 1.3;
    color: rgb(var(--color-foreground));
  }
  .trust-badge__sub {
    font-size: 11px;
    font-weight: 400;
    color: rgba(var(--color-foreground), 0.6);
    display: block;
  }
  @media screen and (max-width: 749px) {
    .trust-badges { padding: 12px; gap: 4px; }
    .trust-badge__text { font-size: 11px; }
  }
</style>

<div class="trust-badges">
  <div class="trust-badge">
    <div class="trust-badge__icon">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13" rx="2"/><polyline points="16 8 20 8 23 11 23 16 20 16"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
    </div>
    <div class="trust-badge__text">
      Livraison offerte
      <span class="trust-badge__sub">2 à 5 semaines</span>
    </div>
  </div>
  <div class="trust-badge">
    <div class="trust-badge__icon">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
    </div>
    <div class="trust-badge__text">
      Garantie 5 ans
      <span class="trust-badge__sub">Fabrication artisanale</span>
    </div>
  </div>
  <div class="trust-badge">
    <div class="trust-badge__icon">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
    </div>
    <div class="trust-badge__text">
      Retours 14 jours
      <span class="trust-badge__sub">Satisfait ou remboursé</span>
    </div>
  </div>
  <div class="trust-badge">
    <div class="trust-badge__icon">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
    </div>
    <div class="trust-badge__text">
      Paiement sécurisé
      <span class="trust-badge__sub">CB, PayPal, Apple Pay</span>
    </div>
  </div>
</div>
