{%- liquid
  assign position = 1
  assign shop_url = shop.url | default: canonical_url | default: request.origin
  assign items = ''
  assign items = items | append: '{"@type":"ListItem","position":1,"name":"Accueil","item":"' | append: shop_url | append: '"}'
  assign position = 2

  comment
    Le filtre "json" produit une chaine JSON valide AVEC ses guillemets
    (ex: "Volant BMW"). Ne jamais chainer "| escape" apres un append : il
    s'appliquerait a toute la chaine accumulee et casserait le JSON.
  endcomment

  case request.page_type
    when 'product'
      assign product_collection = nil

      for collection in product.collections
        if collection.handle contains 'volant'
          assign product_collection = collection
          break
        endif
      endfor

      if product_collection == nil
        for collection in product.collections
          unless collection.handle == 'all'
            assign product_collection = collection
            break
          endunless
        endfor
      endif

      if product_collection
        assign coll_name = product_collection.title | json
        assign items = items | append: ',{"@type":"ListItem","position":' | append: position | append: ',"name":' | append: coll_name | append: ',"item":"' | append: shop_url | append: product_collection.url | append: '"}'
        assign position = position | plus: 1
      endif

      assign prod_name = product.title | json
      assign items = items | append: ',{"@type":"ListItem","position":' | append: position | append: ',"name":' | append: prod_name | append: ',"item":"' | append: canonical_url | append: '"}'

    when 'collection'
      assign coll_name = collection.title | json
      assign items = items | append: ',{"@type":"ListItem","position":' | append: position | append: ',"name":' | append: coll_name | append: ',"item":"' | append: canonical_url | append: '"}'

    when 'article'
      assign blog_name = blog.title | json
      assign items = items | append: ',{"@type":"ListItem","position":' | append: position | append: ',"name":' | append: blog_name | append: ',"item":"' | append: shop_url | append: blog.url | append: '"}'
      assign position = position | plus: 1
      assign article_name = article.title | json
      assign items = items | append: ',{"@type":"ListItem","position":' | append: position | append: ',"name":' | append: article_name | append: ',"item":"' | append: canonical_url | append: '"}'

    when 'page'
      assign page_name = page.title | json
      assign items = items | append: ',{"@type":"ListItem","position":' | append: position | append: ',"name":' | append: page_name | append: ',"item":"' | append: canonical_url | append: '"}'

  endcase
%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [{{ items }}]
}
</script>
