        { "value": "left", "label": "Gauche" },
        { "value": "center", "label": "Centré" },
        { "value": "right", "label": "Droite" }
      ],
      "default": "center"
    },
    {
      "type": "checkbox",
      "id": "bullets_bold",
      "label": "Puces en gras",
      "default": false
    },
    {
      "type": "textarea",
      "id": "bullet1_html",
      "label": "HTML puce 1",
