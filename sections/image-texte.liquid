{% comment %}
  SECTION : media-text-card.liquid
  Description : Section responsive simple avec média (image ou vidéo via URL) + texte et puces.
  Auteur : Votre nom
{% endcomment %}

<div class="media-text-card-section" style="background-color: {{ section.settings.section_bg_color }};">
  <div class="media-text-wrapper" style="
    display: flex;
    flex-direction: {% if section.settings.media_position == 'right' %}row-reverse{% else %}row{% endif %};
    align-items: center;
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto;
    padding: {{ section.settings.section_padding_vertical_desktop }}px {{ section.settings.section_padding_horizontal_desktop }}px;
  ">

    <!-- Conteneur Média -->
    <div class="media-container" style="
      flex: 0 0 auto;
      max-width: {{ section.settings.media_width_desktop }}%;
    ">
      {% if section.settings.media_type == 'image' and section.settings.image %}
        <!-- Affiche une image ou un GIF -->
        <img src="{{ section.settings.image | img_url: 'master' }}" 
             alt="{{ section.settings.alt_text | escape }}" 
             style="width: 100%; height: auto; display: block;" 
             loading="lazy">
      {% elsif section.settings.media_type == 'video' and section.settings.video_url != blank %}
        <!-- Affiche une vidéo MP4 à partir de son URL -->
        <video autoplay loop muted playsinline preload="metadata" style="width: 100%; height: auto; display: block;">
          <source src="{{ section.settings.video_url }}" type="video/mp4">
          Votre navigateur ne supporte pas la balise vidéo.
        </video>
      {% elsif section.settings.media_type == 'youtube' and section.settings.youtube_url != blank %}
        <!-- Affiche une vidéo YouTube -->
        <div class="video-container" style="position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden;">
          <iframe 
            style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;" 
            src="{{ section.settings.youtube_url }}" 
            frameborder="0" 
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
            allowfullscreen>
          </iframe>
        </div>
      {% elsif section.settings.media_type == 'vimeo' and section.settings.vimeo_url != blank %}
        <!-- Affiche une vidéo Vimeo -->
        <div class="video-container" style="position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden;">
          <iframe 
            style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;" 
            src="{{ section.settings.vimeo_url }}" 
            frameborder="0" 
            allow="autoplay; fullscreen; picture-in-picture" 
            allowfullscreen>
          </iframe>
        </div>
      {% endif %}
    </div>

    <!-- Conteneur Texte -->
    <div class="text-card" style="
      flex: 1;
      background-color: {{ section.settings.card_bg_color }};
      padding: {{ section.settings.card_padding_vertical }}px {{ section.settings.card_padding_horizontal }}px;
      border-radius: 16px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.08);
      text-align: {{ section.settings.text_alignment_desktop }};
    ">
      {% if section.settings.heading %}
        <div style="color: {{ section.settings.title_color }};
                   font-size: {{ section.settings.title_font_size_desktop }}px;
                   margin-bottom: 20px;
                   font-weight: {% if section.settings.title_bold %}600{% else %}400{% endif %};
                   letter-spacing: {{ section.settings.title_letter_spacing_desktop }}px;">
          {{ section.settings.heading | raw }}
        </div>
      {% endif %}

      <div class="text-content" style="color: {{ section.settings.text_color }};
                                        font-size: {{ section.settings.text_font_size_desktop }}px;
                                        line-height: 1.8;
                                        font-weight: {% if section.settings.content_bold %}600{% else %}400{% endif %};
                                        letter-spacing: {{ section.settings.text_letter_spacing_desktop }}px;">
        {{ section.settings.content | raw }}
        
        {% if section.settings.embed_video and section.settings.video_embed_code != blank %}
          <!-- Vidéo embarquée dans le contenu -->
          <div class="embedded-video-container" style="margin-top: 20px; position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden;">
            {{ section.settings.video_embed_code | raw }}
          </div>
        {% endif %}
      </div>

      <!-- Liste de puces -->
      <ul class="bullets-list">
        {% if section.settings.bullet1_text or section.settings.bullet1_html %}
          <li class="bullet-item">
            <span class="bullet-icon">{{ section.settings.bullet1_html | raw }}</span>
            <span class="bullet-text">{{ section.settings.bullet1_text | raw }}</span>
          </li>
        {% endif %}
        {% if section.settings.bullet2_text or section.settings.bullet2_html %}
          <li class="bullet-item">
            <span class="bullet-icon">{{ section.settings.bullet2_html | raw }}</span>
            <span class="bullet-text">{{ section.settings.bullet2_text | raw }}</span>
          </li>
        {% endif %}
        {% if section.settings.bullet3_text or section.settings.bullet3_html %}
          <li class="bullet-item">
            <span class="bullet-icon">{{ section.settings.bullet3_html | raw }}</span>
            <span class="bullet-text">{{ section.settings.bullet3_text | raw }}</span>
          </li>
        {% endif %}
      </ul>
    </div>
  </div>
</div>

<style>
  /* Liste de puces : on aligne globalement la colonne (left, center, right) */
  .bullets-list {
    display: flex;
    flex-direction: column; /* empile chaque puce verticalement */
    align-items: {% if section.settings.bullet_alignment == 'center' %}
                   center
                 {% elsif section.settings.bullet_alignment == 'right' %}
                   flex-end
                 {% else %}
                   flex-start
                 {% endif %};
    margin: 20px 0 0;
    padding: 0;
    list-style: none;
  }

  /* Chaque puce : icône et texte en ligne, l'icône reste à gauche */
  .bullet-item {
    display: flex;
    align-items: center;
    justify-content: flex-start; /* force l'icône et le texte à gauche l'un de l'autre */
    margin-bottom: 10px;
  }

  /* L'icône a une largeur fixe de 24px pour former une colonne */
  .bullet-icon {
    display: inline-block;
    width: 24px;
    margin-right: 8px;
    text-align: center;
  }
  
  /* Style du texte des puces */
  .bullet-text {
    font-weight: {% if section.settings.bullets_bold %}600{% else %}400{% endif %};
  }

  /* Style pour la vidéo embarquée */
  .embedded-video-container iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  @media (max-width: 767px) {
    .media-text-wrapper {
      flex-direction: column !important;
      padding: {{ section.settings.section_padding_vertical_mobile }}px {{ section.settings.section_padding_horizontal_mobile }}px !important;
    }
    {% if section.settings.mobile_media_order == 'media-first' %}
      .media-container {
        order: -1;
        margin-bottom: {{ section.settings.mobile_gap }}px;
      }
      .text-card {
        order: 1;
        margin-bottom: 0 !important;
      }
    {% else %}
      .media-container {
        order: 1;
        margin-bottom: 0 !important;
      }
      .text-card {
        order: -1;
        margin-bottom: {{ section.settings.mobile_gap }}px;
      }
    {% endif %}
    .media-container,
    .text-card {
      width: 100% !important;
      max-width: 100% !important;
    }
    .text-card h2 {
      font-size: {{ section.settings.title_font_size_mobile }}px !important;
      letter-spacing: {{ section.settings.title_letter_spacing_mobile }}px !important;
    }
    .text-content {
      font-size: {{ section.settings.text_font_size_mobile }}px !important;
      letter-spacing: {{ section.settings.text_letter_spacing_mobile }}px !important;
    }
  }
</style>

{% schema %}
{
  "name": "Media + Texte",
  "settings": [
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Couleur fond",
      "default": "#f8f8f8"
    },
    {
      "type": "range",
      "id": "section_padding_vertical_desktop",
      "label": "Padding vertical desktop (px)",
      "min": 0,
      "max": 200,
      "step": 5,
      "default": 40
    },
    {
      "type": "range",
      "id": "section_padding_horizontal_desktop",
      "label": "Padding horizontal desktop (px)",
      "min": 0,
      "max": 200,
      "step": 5,
      "default": 20
    },
    {
      "type": "range",
      "id": "section_padding_vertical_mobile",
      "label": "Padding vertical mobile (px)",
      "min": 0,
      "max": 200,
      "step": 5,
      "default": 40
    },
    {
      "type": "range",
      "id": "section_padding_horizontal_mobile",
      "label": "Padding horizontal mobile (px)",
      "min": 0,
      "max": 200,
      "step": 5,
      "default": 20
    },
    {
      "type": "range",
      "id": "mobile_gap",
      "label": "Gap mobile (px)",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 20
    },
    {
      "type": "select",
      "id": "media_type",
      "label": "Type de média",
      "options": [
        { "value": "image", "label": "Image/GIF" },
        { "value": "video", "label": "Vidéo (MP4)" },
        { "value": "youtube", "label": "YouTube" },
        { "value": "vimeo", "label": "Vimeo" }
      ],
      "default": "image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image / GIF"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "URL vidéo (MP4)",
      "default": "https://example.com/video.mp4",
      "info": "Utilisé uniquement si le type de média est 'Vidéo (MP4)'"
    },
    {
      "type": "text",
      "id": "youtube_url",
      "label": "URL vidéo YouTube",
      "default": "https://www.youtube.com/embed/XXXXXXXXXXX",
      "info": "Format: https://www.youtube.com/embed/ID_VIDEO"
    },
    {
      "type": "text",
      "id": "vimeo_url",
      "label": "URL vidéo Vimeo",
      "default": "https://player.vimeo.com/video/XXXXXXXXX",
      "info": "Format: https://player.vimeo.com/video/ID_VIDEO"
    },
    {
      "type": "text",
      "id": "alt_text",
      "label": "Texte alternatif",
      "default": "Description du média"
    },
    {
      "type": "range",
      "id": "media_width_desktop",
      "label": "Largeur média desktop (%)",
      "min": 20,
      "max": 80,
      "step": 5,
      "default": 40
    },
    {
      "type": "select",
      "id": "media_position",
      "label": "Position média desktop",
      "options": [
        { "value": "left", "label": "Gauche" },
        { "value": "right", "label": "Droite" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "mobile_media_order",
      "label": "Ordre mobile",
      "options": [
        { "value": "media-first", "label": "Média avant texte" },
        { "value": "media-last", "label": "Média après texte" }
      ],
      "default": "media-first"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Couleur bloc texte",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "card_padding_vertical",
      "label": "Padding vertical bloc texte (px)",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 20
    },
    {
      "type": "range",
      "id": "card_padding_horizontal",
      "label": "Padding horizontal bloc texte (px)",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 35
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre (H2)",
      "default": "Installation Rapide, Zéro Stress !"
    },
    {
      "type": "checkbox",
      "id": "title_bold",
      "label": "Titre en gras",
      "default": true
    },
    {
      "type": "textarea",
      "id": "content",
      "label": "Contenu",
      "default": "<p>Plus besoin de passer des heures à assembler. L'installation se fait en quelques minutes, sans outils complexes.</p>",
      "info": "Vous pouvez utiliser les balises HTML comme <strong> pour mettre en gras ou <em> pour l'italique."
    },
    {
      "type": "checkbox", 
      "id": "content_bold",
      "label": "Contenu en gras",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "embed_video",
      "label": "Ajouter une vidéo dans le contenu",
      "default": false
    },
    {
      "type": "textarea",
      "id": "video_embed_code",
