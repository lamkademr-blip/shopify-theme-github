    {
      "type": "color",
      "id": "title_color",
      "label": "Couleur titre",
      "default": "#e67e22"
    },
    {
      "type": "range",
      "id": "title_font_size_desktop",
      "label": "Taille titre desktop (px)",
      "min": 16,
      "max": 50,
      "step": 1,
      "default": 28
    },
    {
      "type": "range",
      "id": "title_font_size_mobile",
      "label": "Taille titre mobile (px)",
      "min": 16,
      "max": 50,
      "step": 1,
      "default": 24
    },
