      "step": 1,
      "default": 14
    },
    {
      "type": "range",
      "id": "text_letter_spacing_desktop",
      "label": "Espacement lettres texte desktop (px)",
      "min": 0,
      "max": 10,
      "step": 0.5,
      "default": 0
    },
    {
