{{ 'component-list-menu.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .brand-bar {
    background: rgba(0, 0, 0, 0.03);
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
    padding: 0;
  }

  .brand-bar__wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: nowrap;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    gap: 0;
    max-width: 100%;
    padding: 0 1rem;
  }

  .brand-bar__wrapper::-webkit-scrollbar {
    display: none;
  }

  .brand-bar__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: inline-flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0;
  }

  .brand-bar__item {
    display: inline-flex;
  }

  .brand-bar__link {
    display: inline-flex;
    align-items: center;
    padding: 0.8rem 1.6rem;
    font-size: 1.2rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    color: rgba(var(--color-foreground), 0.75);
    white-space: nowrap;
    transition: color 0.2s ease, background-color 0.2s ease;
    border-radius: 0;
    position: relative;
  }

  .brand-bar__link:hover,
  .brand-bar__link:focus-visible {
    color: rgb(var(--color-foreground));
    background-color: rgba(0, 0, 0, 0.03);
    text-decoration: none;
  }

  .brand-bar__link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 1.2rem;
    right: 1.2rem;
    height: 2px;
    background: rgb(var(--color-foreground));
    transform: scaleX(0);
    transition: transform 0.2s ease;
  }

  .brand-bar__link:hover::after {
    transform: scaleX(1);
  }

  .brand-bar__separator {
    display: inline-flex;
    align-items: center;
    color: rgba(var(--color-foreground), 0.15);
    font-size: 1rem;
    user-select: none;
  }

  @media screen and (max-width: 749px) {
    .brand-bar__wrapper {
      justify-content: flex-start;
      padding: 0;
    }

    .brand-bar__list {
      flex-wrap: nowrap;
      justify-content: flex-start;
      padding: 0 0.8rem;
    }

    .brand-bar__link {
      padding: 0.6rem 1rem;
      font-size: 1rem;
    }

    .brand-bar__separator {
      display: none;
    }
  }
{%- endstyle -%}

<div class="brand-bar color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width brand-bar__wrapper">
    <ul class="brand-bar__list" role="list">
      {%- for block in section.blocks -%}
        {%- if block.settings.brand_url != blank -%}
          <li class="brand-bar__item">
            <a href="{{ block.settings.brand_url }}"
               class="brand-bar__link"
               {% if block.settings.open_new_tab %}target="_blank" rel="noopener"{% endif %}
            >
              {{ block.settings.brand_name | escape }}
            </a>
          </li>
          {%- unless forloop.last -%}
            <li class="brand-bar__separator" aria-hidden="true">|</li>
          {%- endunless -%}
        {%- endif -%}
      {%- endfor -%}
    </ul>
  </div>
</div>

