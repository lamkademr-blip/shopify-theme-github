{{ 'section-brand-bar.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #brand-bar-{{ section.id }} {
    --brand-bar-bg: {{ section.settings.background_color }};
    --brand-bar-text: {{ section.settings.text_color }};
    --brand-bar-accent: {{ section.settings.accent_color }};
    --brand-bar-price: {{ section.settings.price_color }};
    --brand-bar-hover: {{ section.settings.hover_bg }};
    --brand-bar-radius: {{ section.settings.card_radius }}px;
  }
{%- endstyle -%}

<div id="brand-bar-{{ section.id }}" class="brand-bar">
  <div class="page-width brand-bar__container">
    <div class="brand-bar__inner">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'brand' -%}
            <a
              href="{{ block.settings.link | default: '#' }}"
              class="brand-bar__card"
              {{ block.shopify_attributes }}
            >
              <div class="brand-bar__card-image-wrap">
                {%- if block.settings.image != blank -%}
                  {%- assign img_height = block.settings.image.width | divided_by: block.settings.image.aspect_ratio -%}
                  {{
                    block.settings.image
                    | image_url: width: 300
                    | image_tag:
                      width: block.settings.image.width,
                      height: img_height,
                      class: 'brand-bar__card-image',
                      sizes: '150px',
                      widths: '150, 300',
                      loading: 'lazy'
                  }}
                {%- else -%}
                  <div class="brand-bar__card-placeholder">
                    <span>{{ block.settings.name | slice: 0, 2 | upcase }}</span>
                  </div>
                {%- endif -%}
              </div>
              <div class="brand-bar__card-info">
                <span class="brand-bar__card-name">{{ block.settings.name }}</span>
                {%- if block.settings.price_from != blank -%}
                  <span class="brand-bar__card-price">{{ block.settings.price_from }}</span>
                {%- endif -%}
              </div>
            </a>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Barre des marques",
  "tag": "section",
  "class": "section",
  "limit": 1,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Apparence"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Fond",
      "default": "#FAFAFA"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Texte",
      "default": "#1A1A1A"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#C8A97E"
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Prix",
      "default": "#C8A97E"
    },
    {
      "type": "color",
      "id": "hover_bg",
      "label": "Fond au survol",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "card_radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Coins arrondis",
      "default": 8
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Marque",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image du produit"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Nom de la marque",
          "default": "BMW"
        },
        {
          "type": "text",
          "id": "price_from",
          "label": "Prix (à partir de)",
          "default": "À partir de 399€"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Lien vers la collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Barre des marques",
      "blocks": [
        { "type": "brand", "settings": { "name": "BMW", "price_from": "À partir de 399€" } },
        { "type": "brand", "settings": { "name": "AUDI", "price_from": "À partir de 399€" } },
        { "type": "brand", "settings": { "name": "MERCEDES", "price_from": "À partir de 429€" } },
        { "type": "brand", "settings": { "name": "PORSCHE", "price_from": "À partir de 599€" } },
        { "type": "brand", "settings": { "name": "VOLKSWAGEN", "price_from": "À partir de 349€" } },
        { "type": "brand", "settings": { "name": "TESLA", "price_from": "À partir de 449€" } }
      ]
    }
  ]
}
{% endschema %}