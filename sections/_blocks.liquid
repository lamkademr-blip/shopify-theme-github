{{ 'custom-blocks.css' | asset_url | stylesheet_tag }}
<div class="custom-blocks-section" style="max-width: var(--page-width); margin: 0 auto;">
  {% content_for 'blocks' %}
</div>

{% schema %}
{
  "name": "AI Blocks",
  "class": "section",
  "tag": "section",
  "settings": [],
  "blocks": [
    { "type": "@theme" },
    { "type": "@app" }
  ],
  "max_blocks": 20,
  "presets": [
    {
      "name": "AI Blocks",
      "blocks": []
    }
  ]
}
{% endschema %}