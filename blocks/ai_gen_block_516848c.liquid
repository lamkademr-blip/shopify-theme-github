    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 40,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "Espacement bas",
      "default": 120
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "min": 20,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Espacement horizontal",
      "default": 60
    },
    {
      "type": "range",
      "id": "content_max_width",
      "min": 600,
      "max": 1200,
      "step": 20,
      "unit": "px",
      "label": "Largeur maximale du contenu",
      "default": 800
