{% doc %}
  @prompt
    cree une section faisant defiler des images montrant le logo de nos partenaires, je veux que le titre soit en balise div, je veux que les logos soient de couleur deja et choisir l nombre de logo a defiler
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-partners-carousel-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
    background-color: {{ block.settings.background_color }};
    overflow: hidden;
  }

  .ai-partners-carousel__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-partners-carousel__heading-{{ ai_gen_id }} {
    text-align: center;
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
  }

  .ai-partners-carousel__track-wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    width: 100%;
  }

  .ai-partners-carousel__track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.logo_spacing }}px;
    animation: ai-partners-scroll-{{ ai_gen_id }} {{ block.settings.scroll_speed }}s linear infinite;
    will-change: transform;
  }

  .ai-partners-carousel__track-{{ ai_gen_id }}:hover {
    animation-play-state: paused;
  }

  .ai-partners-carousel__logo-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.logo_width }}px;
    height: {{ block.settings.logo_height }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.logo_background }};
    border-radius: {{ block.settings.logo_border_radius }}px;
    padding: {{ block.settings.logo_padding }}px;
    transition: transform 0.3s ease;
  }

  .ai-partners-carousel__logo-{{ ai_gen_id }}:hover {
    transform: scale(1.05);
  }

  .ai-partners-carousel__logo-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform 0.3s ease;
  }

  .ai-partners-carousel__logo-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.logo_border_radius }}px;
  }

  .ai-partners-carousel__logo-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  @keyframes ai-partners-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(calc(-50% - {{ block.settings.logo_spacing | divided_by: 2.0 }}px));
    }
  }

  @media screen and (max-width: 749px) {
    .ai-partners-carousel__logo-{{ ai_gen_id }} {
      width: {{ block.settings.logo_width | times: 0.7 }}px;
      height: {{ block.settings.logo_height | times: 0.7 }}px;
    }

    .ai-partners-carousel__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<partners-carousel-{{ ai_gen_id }} class="ai-partners-carousel-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-partners-carousel__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <div class="ai-partners-carousel__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</div>
    {% endif %}

    <div class="ai-partners-carousel__track-wrapper-{{ ai_gen_id }}">
      <div class="ai-partners-carousel__track-{{ ai_gen_id }}">
        {% for i in (1..block.settings.logo_count) %}
          {% assign logo_key = 'logo_' | append: i %}
          {% assign logo = block.settings[logo_key] %}
          
          {% if logo != blank %}
            <div class="ai-partners-carousel__logo-{{ ai_gen_id }}">
              <img
                src="{{ logo | image_url: width: 400 }}"
                alt="{{ logo.alt | escape }}"
                loading="lazy"
                width="{{ block.settings.logo_width }}"
                height="{{ block.settings.logo_height }}"
              >
            </div>
          {% else %}
            <div class="ai-partners-carousel__logo-{{ ai_gen_id }}">
              <div class="ai-partners-carousel__logo-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            </div>
          {% endif %}
        {% endfor %}

        {% for i in (1..block.settings.logo_count) %}
          {% assign logo_key = 'logo_' | append: i %}
          {% assign logo = block.settings[logo_key] %}
          
          {% if logo != blank %}
            <div class="ai-partners-carousel__logo-{{ ai_gen_id }}">
              <img
                src="{{ logo | image_url: width: 400 }}"
                alt="{{ logo.alt | escape }}"
                loading="lazy"
                width="{{ block.settings.logo_width }}"
                height="{{ block.settings.logo_height }}"
              >
            </div>
          {% else %}
            <div class="ai-partners-carousel__logo-{{ ai_gen_id }}">
              <div class="ai-partners-carousel__logo-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</partners-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class PartnersCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-partners-carousel__track-{{ ai_gen_id }}');
        this.adjustScrollSpeed();
      }

      adjustScrollSpeed() {
        if (!this.track) return;
        
        const trackWidth = this.track.scrollWidth / 2;
        const speed = {{ block.settings.scroll_speed }};
        
        this.track.style.animationDuration = `${speed}s`;
      }
    }

    customElements.define('partners-carousel-{{ ai_gen_id }}', PartnersCarousel{{ ai_gen_id }});
  })();
</script>

