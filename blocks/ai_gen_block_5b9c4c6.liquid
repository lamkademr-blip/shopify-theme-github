{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-process-steps-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px {{ block.settings.padding_horizontal }}px;
    background: linear-gradient(
      {% if block.settings.gradient_direction == 'top_to_bottom' %}to bottom{% elsif block.settings.gradient_direction == 'left_to_right' %}to right{% elsif block.settings.gradient_direction == 'top_left_to_bottom_right' %}to bottom right{% elsif block.settings.gradient_direction == 'top_right_to_bottom_left' %}to bottom left{% endif %},
      {{ block.settings.gradient_color_1 }},
      {{ block.settings.gradient_color_2 }}
    );
  }

  .ai-process-steps__container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
  }

  .ai-process-steps__eyebrow-{{ ai_gen_id }} {
    text-align: {{ block.settings.alignment }};
    color: {{ block.settings.eyebrow_color }};
    font-size: {{ block.settings.eyebrow_size }}px;
    letter-spacing: {{ block.settings.eyebrow_letter_spacing }}px;
    font-weight: 600;
    margin: 0 0 40px 0;
    text-transform: uppercase;
  }

  .ai-process-steps__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.gap }}px;
    align-items: start;
  }

  .ai-process-steps__step-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: {{ block.settings.alignment }};
    text-align: {{ block.settings.alignment }};
  }

  .ai-process-steps__icon-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    background-color: {{ block.settings.icon_background }};
    border-radius: {{ block.settings.icon_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
    flex-shrink: 0;
  }

  .ai-process-steps__icon-{{ ai_gen_id }} {
    width: calc({{ block.settings.icon_size }}px * 0.5);
    height: calc({{ block.settings.icon_size }}px * 0.5);
    color: {{ block.settings.icon_color }};
  }

  .ai-process-steps__title-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
    {% if block.settings.alignment == 'center' %}
      justify-content: center;
    {% elsif block.settings.alignment == 'right' %}
      justify-content: flex-end;
    {% else %}
      justify-content: flex-start;
    {% endif %}
  }

  .ai-process-steps__number-{{ ai_gen_id }} {
    color: {{ block.settings.title_color }};
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_font_weight }};
    letter-spacing: {{ block.settings.title_letter_spacing }}px;
    margin: 0;
  }

  .ai-process-steps__title-{{ ai_gen_id }} {
    color: {{ block.settings.title_color }};
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_font_weight }};
    letter-spacing: {{ block.settings.title_letter_spacing }}px;
    margin: 0;
  }

  .ai-process-steps__description-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
    margin: 0;
  }

  @media screen and (max-width: 989px) {
    .ai-process-steps__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
      gap: {{ block.settings.gap | times: 0.75 }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-process-steps-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top | times: 0.6 }}px {{ block.settings.padding_horizontal | times: 0.5 }}px {{ block.settings.padding_bottom | times: 0.6 }}px {{ block.settings.padding_horizontal | times: 0.5 }}px;
    }

    .ai-process-steps__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
      gap: {{ block.settings.gap | times: 0.5 }}px;
    }

    .ai-process-steps__eyebrow-{{ ai_gen_id }} {
      margin-bottom: 30px;
    }
  }
{% endstyle %}

<process-steps-{{ ai_gen_id }} class="ai-process-steps-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-process-steps__container-{{ ai_gen_id }}">
    {% if block.settings.eyebrow_text != blank %}
      <div class="ai-process-steps__eyebrow-{{ ai_gen_id }}">
        {{ block.settings.eyebrow_text }}
      </div>
    {% endif %}

    <div class="ai-process-steps__grid-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign step_enabled_key = 'step_' | append: i | append: '_enabled'
          assign step_number_key = 'step_' | append: i | append: '_number'
          assign step_title_key = 'step_' | append: i | append: '_title'
          assign step_description_key = 'step_' | append: i | append: '_description'
          assign step_icon_key = 'step_' | append: i | append: '_icon'

          assign step_enabled = block.settings[step_enabled_key]
          assign step_number = block.settings[step_number_key]
          assign step_title = block.settings[step_title_key]
          assign step_description = block.settings[step_description_key]
          assign step_icon = block.settings[step_icon_key]
        %}

        {% if step_enabled %}
          <div class="ai-process-steps__step-{{ ai_gen_id }}">
            <div class="ai-process-steps__icon-wrapper-{{ ai_gen_id }}">
              <svg class="ai-process-steps__icon-{{ ai_gen_id }}" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                {% if step_icon == 'sliders' %}
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path>
                {% elsif step_icon == 'edit' %}
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                {% elsif step_icon == 'box' %}
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
                {% elsif step_icon == 'shield' %}
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                {% elsif step_icon == 'star' %}
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"></path>
                {% elsif step_icon == 'check' %}
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                {% elsif step_icon == 'truck' %}
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0"></path>
                {% else %}
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                {% endif %}
              </svg>
            </div>

            <div class="ai-process-steps__title-wrapper-{{ ai_gen_id }}">
              {% if step_number != blank %}
                <h3 class="ai-process-steps__number-{{ ai_gen_id }}">{{ step_number }}</h3>
              {% endif %}
              {% if step_title != blank %}
                <h3 class="ai-process-steps__title-{{ ai_gen_id }}">{{ step_title }}</h3>
              {% endif %}
            </div>

            {% if step_description != blank %}
              <p class="ai-process-steps__description-{{ ai_gen_id }}">{{ step_description }}</p>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</process-steps-{{ ai_gen_id }}>

<script>
  (function() {
    class ProcessSteps{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.adjustLayout();
        window.addEventListener('resize', () => this.adjustLayout());
      }

      adjustLayout() {
        const steps = this.querySelectorAll('.ai-process-steps__step-{{ ai_gen_id }}');
        steps.forEach(step => {
          step.style.opacity = '1';
        });
      }
    }

    customElements.define('process-steps-{{ ai_gen_id }}', ProcessSteps{{ ai_gen_id }});
  })();
</script>

