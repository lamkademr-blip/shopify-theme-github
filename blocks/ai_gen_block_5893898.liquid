{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100vh;
    min-height: 500px;
    overflow: hidden;
    display: block;
  }

  .ai-hero-background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-hero-background-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .ai-hero-background-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #1a1a1a;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-hero-background-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 600px;
    max-height: 600px;
    opacity: 0.3;
  }

  .ai-hero-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 2;
    background: linear-gradient(
      to right,
      rgba(0, 0, 0, {{ block.settings.overlay_opacity | divided_by: 100.0 }}) 0%,
      rgba(0, 0, 0, {{ block.settings.overlay_opacity | divided_by: 100.0 | times: 0.3 }}) 100%
    );
  }

  .ai-hero-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    height: 100%;
    display: flex;
    align-items: center;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_right }}px {{ block.settings.padding_bottom }}px {{ block.settings.padding_left }}px;
  }

  .ai-hero-content-inner-{{ ai_gen_id }} {
    max-width: {{ block.settings.content_max_width }}px;
  }

  .ai-hero-eyebrow-{{ ai_gen_id }} {
    font-size: {{ block.settings.eyebrow_size }}px;
    letter-spacing: {{ block.settings.eyebrow_letter_spacing }}px;
    color: {{ block.settings.eyebrow_color }};
    opacity: {{ block.settings.eyebrow_opacity | divided_by: 100.0 }};
    margin: 0 0 20px 0;
    text-transform: uppercase;
    font-weight: 400;
  }

  .ai-hero-headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.headline_size }}px;
    letter-spacing: {{ block.settings.headline_letter_spacing }}px;
    line-height: {{ block.settings.headline_line_height }};
    color: {{ block.settings.headline_color }};
    margin: 0 0 40px 0;
    font-weight: {{ block.settings.headline_weight }};
  }

  .ai-hero-buttons-{{ ai_gen_id }} {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .ai-hero-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    font-size: {{ block.settings.button_font_size }}px;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
    border: none;
    letter-spacing: 1px;
    font-weight: 500;
  }

  .ai-hero-button-primary-{{ ai_gen_id }} {
    background-color: {{ block.settings.primary_bg }};
    color: {{ block.settings.primary_text_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
  }

  .ai-hero-button-primary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.primary_hover_bg }};
    color: {{ block.settings.primary_hover_text }};
  }

  .ai-hero-button-secondary-{{ ai_gen_id }} {
    background-color: {{ block.settings.secondary_bg }};
    color: {{ block.settings.secondary_text_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
  }

  .ai-hero-button-secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.secondary_hover_bg }};
    color: {{ block.settings.secondary_hover_text }};
  }

  .ai-hero-whatsapp-icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    fill: currentColor;
  }

  @media screen and (max-width: 749px) {
    .ai-hero-{{ ai_gen_id }} {
      height: {{ block.settings.mobile_height }}vh;
    }

    .ai-hero-content-{{ ai_gen_id }} {
      padding: {{ block.settings.mobile_padding }}px;
    }

    .ai-hero-eyebrow-{{ ai_gen_id }} {
      font-size: {{ block.settings.eyebrow_size | times: 0.8 }}px;
    }

    .ai-hero-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size | times: 0.5 }}px;
    }

    .ai-hero-buttons-{{ ai_gen_id }} {
      flex-direction: column;
      width: 100%;
    }

    .ai-hero-button-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<hero-block-{{ ai_gen_id }} class="ai-hero-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-background-{{ ai_gen_id }}">
    {% if block.settings.background_image %}
      <img
        src="{{ block.settings.background_image | image_url: width: 2400 }}"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
      >
    {% else %}
      <div class="ai-hero-background-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
      </div>
    {% endif %}
  </div>

  <div class="ai-hero-overlay-{{ ai_gen_id }}"></div>

  <div class="ai-hero-content-{{ ai_gen_id }}">
    <div class="ai-hero-content-inner-{{ ai_gen_id }}">
      {% if block.settings.eyebrow_text != blank %}
        <div class="ai-hero-eyebrow-{{ ai_gen_id }}">{{ block.settings.eyebrow_text }}</div>
      {% endif %}

      {% if block.settings.headline_text != blank %}
        <h1 class="ai-hero-headline-{{ ai_gen_id }}">{{ block.settings.headline_text }}</h1>
      {% endif %}

      <div class="ai-hero-buttons-{{ ai_gen_id }}">
        {% if block.settings.primary_label != blank %}
          <a
            href="{{ block.settings.primary_link }}"
            class="ai-hero-button-{{ ai_gen_id }} ai-hero-button-primary-{{ ai_gen_id }}"
          >
            {{ block.settings.primary_label }}
          </a>
        {% endif %}

        {% if block.settings.secondary_label != blank %}
          <a
            href="{{ block.settings.secondary_link }}"
            class="ai-hero-button-{{ ai_gen_id }} ai-hero-button-secondary-{{ ai_gen_id }}"
          >
            <svg class="ai-hero-whatsapp-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
            </svg>
            {{ block.settings.secondary_label }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</hero-block-{{ ai_gen_id }}>

<script>
  (function() {
    class HeroBlock{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.adjustHeight();
        window.addEventListener('resize', () => this.adjustHeight());
      }

      adjustHeight() {
        const vh = window.innerHeight * 0.01;
        this.style.setProperty('--vh', `${vh}px`);
      }
    }

    customElements.define('hero-block-{{ ai_gen_id }}', HeroBlock{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Steering wheel hero",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Overlay opacity",
      "default": 55
    },
    {
      "type": "header",
      "content": "Eyebrow text"
    },
    {
      "type": "text",
      "id": "eyebrow_text",
      "label": "Text",
      "default": "CUSTOMIZE YOURS NOW."
    },
    {
      "type": "range",
      "id": "eyebrow_size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Font size",
      "default": 12
    },
    {
      "type": "range",
      "id": "eyebrow_letter_spacing",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "unit": "px",
      "label": "Letter spacing",
      "default": 2
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "eyebrow_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Opacity",
      "default": 85
    },
    {
      "type": "header",
      "content": "Headline"
    },
    {
      "type": "textarea",
      "id": "headline_text",
      "label": "Text",
      "default": "HOME OF ALL CUSTOM STEERING WHEELS."
    },
    {
      "type": "range",
      "id": "headline_size",
      "min": 24,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Font size",
      "default": 64
    },
    {
      "type": "range",
      "id": "headline_letter_spacing",
      "min": 0,
      "max": 10,
      "step": 0.5,
      "unit": "px",
      "label": "Letter spacing",
      "default": 2
    },
    {
      "type": "range",
      "id": "headline_line_height",
      "min": 1,
      "max": 2,
      "step": 0.1,
      "label": "Line height",
      "default": 1.1
    },
    {
      "type": "select",
      "id": "headline_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "300",
          "label": "Light"
        },
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "300"
    },
    {
      "type": "color",
      "id": "headline_color",
      "label": "Color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Primary button"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Label",
      "default": "BUILD YOUR WHEEL"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Link"
    },
    {
      "type": "color",
      "id": "primary_bg",
      "label": "Background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "primary_text_color",
      "label": "Text",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "primary_hover_bg",
      "label": "Hover background",
      "default": "#E5E5E5"
    },
    {
      "type": "color",
      "id": "primary_hover_text",
      "label": "Hover text",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Secondary button"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Label",
      "default": "WHATSAPP"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Link"
    },
    {
      "type": "color",
      "id": "secondary_bg",
      "label": "Background",
      "default": "#25D366"
    },
    {
      "type": "color",
      "id": "secondary_text_color",
      "label": "Text",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "secondary_hover_bg",
      "label": "Hover background",
      "default": "#1EAA52"
    },
    {
      "type": "color",
      "id": "secondary_hover_text",
      "label": "Hover text",
      "default": "#FFFFFF"
