{% doc %}
  @prompt
    {
      "task": "Créer une nouvelle section personnalisée Shopify (fichier .liquid avec {% schema %})",
    
      "section_name": "BOKU - Les 3 Modes d'Utilisation",
    
      "description": "Section interactive 'Comment ça marche' montrant les 3 modes du bidet BOKU avec 3 boutons. Cliquer sur un bouton affiche le contenu correspondant en dessous, avec un seul contenu visible à la fois. Design moderne, propre, mobile-first, inspiré de helloboku.com.",
    
      "layout": {
        "order": [
          "1. Titre + sous-titre (texte simple, PAS de balise hn — utiliser un <p> ou <span> avec une classe CSS qui applique une taille titre, ex: font-size: 2rem; font-weight: bold)",
          "2. Boutons de sélection d'étapes (tout en haut du contenu interactif)",
          "3. Image OU vidéo (embed YouTube/Vimeo ou balise <video>) du mode sélectionné",
          "4. Texte d'explication du mode sélectionné"
        ],
    
        "title": {
          "text": "Un bouton pour les nettoyer tous",
          "subtitle": "Sélectionnez les différents modes d'utilisation grâce au bouton molette multifonctions",
          "html_rule": "Ne PAS utiliser de balises h1/h2/h3/h4/h5/h6. Utiliser <p class='boku-section-title'> avec CSS font-size et font-weight pour simuler un titre visuel."
        },
    
        "buttons": {
          "position": "tout en haut de la zone interactive, AVANT l'image/vidéo et le texte",
          "style": "horizontaux sur desktop, empilés sur mobile",
          "alignment": "center",
          "appearance": {
            "default": "fond transparent, bordure visible (ex: 1-2px solid couleur thème), texte couleur thème",
            "active": "fond plein (couleur thème, ex: #003366), texte blanc, pas de bordure ou bordure assortie",
            "hover": "légèrement plus clair ou opacité réduite sur le fond",
            "shape": "légèrement arrondis (border-radius: 6-8px) ou pilule (border-radius: 999px)"
          }
        },
    
        "media": {
          "position": "juste après les boutons, AVANT le texte d'explication",
          "type": "image OU vidéo selon la configuration du block",
          "image": "balise <img> avec l'image Shopify du block",
          "video": {
            "support": [
              "URL YouTube (ex: https://www.youtube.com/watch?v=XXXX) → embed via <iframe>",
              "URL Vimeo (ex: https://vimeo.com/XXXX) → embed via <iframe>",
              "Fichier vidéo Shopify (type: video_url) → balise <video> avec <source>"
            ],
            "behavior": "si un champ vidéo est renseigné dans le block, afficher la vidéo à la place de l'image",
            "responsive": "ratio 16:9 via padding-top trick ou aspect-ratio CSS, 100% width"
          },
          "priority": "si video_url est renseigné → afficher la vidéo ; sinon → afficher l'image"
        },
    
        "content_switch": {
          "behavior": "un seul contenu affiché à la fois (image/vidéo + texte)",
          "animation": "fade-in simple (CSS opacity transition, 0.3s ease)",
          "structure_desktop": "image/vidéo à gauche, texte à droite (layout 50/50 ou 60/40)",
          "structure_mobile": "image/vidéo en pleine largeur en haut, texte en dessous"
        }
      },
    
      "buttons_list": [
        {
          "label": "Mode auto-lavage des buses",
          "id": "auto-lavage"
        },
        {
          "label": "Mode lavage postérieur",
          "id": "posterieur"
        },
        {
          "label": "Mode lavage féminin",
          "id": "feminin"
        }
      ],
    
      "contents": [
        {
          "mode_id": "auto-lavage",
          "title": "Mode auto-lavage des buses",
          "media_description": "Image ou vidéo : gros plan sur les buses du bidet en train de se rincer automatiquement",
          "text": "Le mode auto-lavage nettoie automatiquement les buses après chaque utilisation pour une hygiène maximale. Activez-le d'un simple geste pour garder votre bidet toujours propre et prêt."
        },
        {
          "mode_id": "posterieur",
          "title": "Mode lavage postérieur",
          "media_description": "Image ou vidéo : illustration ou photo du jet d'eau dirigé vers l'arrière",
          "text": "Pour une hygiène postérieure optimale. Le jet précis et réglable nettoie en profondeur après les selles, pour une sensation de fraîcheur immédiate sans papier excessif."
        },
        {
          "mode_id": "feminin",
          "title": "Mode lavage féminin",
          "media_description": "Image ou vidéo : jet d'eau doux dirigé vers l'avant (zone intime féminine)",
          "text": "Spécialement conçu pour les femmes. Un lavage doux et efficace pour l'hygiène intime, parfait pendant les règles ou après les toilettes, pour plus de confort et de bien-être."
        }
      ],
    
      "schema_requirements": {
