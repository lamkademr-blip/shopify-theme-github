{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .boku-modes-block-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding_top }}px 20px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    margin: 0 auto;
  }

  .boku-modes-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
  }

  .boku-modes-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .boku-section-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 700;
    color: {{ block.settings.text_color }};
    margin: 0 0 12px 0;
    line-height: 1.2;
  }

  .boku-section-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.text_color }};
    opacity: 0.8;
    margin: 0;
    line-height: 1.5;
  }

  .boku-modes-buttons-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-bottom: 40px;
    flex-wrap: wrap;
  }

  .boku-mode-button-{{ ai_gen_id }} {
    padding: 14px 28px;
    background-color: transparent;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    color: {{ block.settings.button_text_color }};
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    white-space: nowrap;
  }

  .boku-mode-button-{{ ai_gen_id }}:hover {
    opacity: 0.8;
  }

  .boku-mode-button-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.button_active_bg }};
    color: {{ block.settings.button_active_text }};
    border-color: {{ block.settings.button_active_bg }};
  }

  .boku-modes-content-{{ ai_gen_id }} {
    position: relative;
    min-height: 400px;
  }

  .boku-mode-item-{{ ai_gen_id }} {
    display: none;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .boku-mode-item-{{ ai_gen_id }}.active {
    display: grid;
    opacity: 1;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: center;
  }

  .boku-mode-media-{{ ai_gen_id }} {
    width: 100%;
    position: relative;
  }

  .boku-mode-media-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    border-radius: {{ block.settings.media_border_radius }}px;
    display: block;
  }

  .boku-video-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-top: 56.25%;
    border-radius: {{ block.settings.media_border_radius }}px;
    overflow: hidden;
  }

  .boku-video-wrapper-{{ ai_gen_id }} iframe,
  .boku-video-wrapper-{{ ai_gen_id }} video {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .boku-mode-text-{{ ai_gen_id }} {
    padding: 20px;
  }

  .boku-mode-text-{{ ai_gen_id }} h3 {
    font-size: {{ block.settings.mode_title_size }}px;
    font-weight: 700;
    color: {{ block.settings.text_color }};
    margin: 0 0 16px 0;
    line-height: 1.3;
  }

  .boku-mode-text-{{ ai_gen_id }} p {
    font-size: {{ block.settings.mode_text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    margin: 0;
  }

  .boku-media-placeholder-{{ ai_gen_id }} {
    width: 100%;
    padding-top: 56.25%;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.media_border_radius }}px;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .boku-media-placeholder-{{ ai_gen_id }} svg {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 60%;
    height: 60%;
    max-width: 200px;
    max-height: 200px;
  }

  @media screen and (max-width: 749px) {
    .boku-modes-block-{{ ai_gen_id }} {
      width: 100%;
    }

    .boku-modes-buttons-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: stretch;
    }

    .boku-mode-button-{{ ai_gen_id }} {
      width: 100%;
      text-align: center;
    }

    .boku-mode-item-{{ ai_gen_id }}.active {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .boku-section-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.7);
    }

    .boku-section-subtitle-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subtitle_size }}px * 0.9);
    }

    .boku-mode-text-{{ ai_gen_id }} h3 {
      font-size: calc({{ block.settings.mode_title_size }}px * 0.85);
    }

    .boku-mode-text-{{ ai_gen_id }} p {
      font-size: calc({{ block.settings.mode_text_size }}px * 0.95);
    }
  }
{% endstyle %}

<boku-modes-block-{{ ai_gen_id }} class="boku-modes-block-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="boku-modes-container-{{ ai_gen_id }}">
    <div class="boku-modes-header-{{ ai_gen_id }}">
      {% if block.settings.title != blank %}
        <p class="boku-section-title-{{ ai_gen_id }}">{{ block.settings.title }}</p>
      {% endif %}
      {% if block.settings.subtitle != blank %}
        <div class="boku-section-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</div>
      {% endif %}
    </div>

    <div class="boku-modes-buttons-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% assign label_key = 'mode_' | append: i | append: '_label' %}
        {% assign label = block.settings[label_key] %}
        {% if label != blank %}
          <button
            class="boku-mode-button-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
            data-mode-index="{{ i }}"
            aria-label="{{ label }}"
          >
            {{ label }}
          </button>
        {% endif %}
      {% endfor %}
    </div>

    <div class="boku-modes-content-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% liquid
          assign label_key = 'mode_' | append: i | append: '_label'
          assign title_key = 'mode_' | append: i | append: '_title'
          assign desc_key = 'mode_' | append: i | append: '_description'
          assign image_key = 'mode_' | append: i | append: '_image'
          assign video_key = 'mode_' | append: i | append: '_video_url'

          assign label = block.settings[label_key]
          assign title = block.settings[title_key]
          assign description = block.settings[desc_key]
          assign image = block.settings[image_key]
          assign video_url = block.settings[video_key]
        %}

        {% if label != blank %}
          <div
            class="boku-mode-item-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
            data-mode-content="{{ i }}"
          >
            <div class="boku-mode-media-{{ ai_gen_id }}">
              {% if video_url != blank %}
                <div class="boku-video-wrapper-{{ ai_gen_id }}">
                  {% if video_url contains 'youtube.com' or video_url contains 'youtu.be' %}
                    {% assign video_id = '' %}
                    {% if video_url contains 'watch?v=' %}
                      {% assign video_id = video_url | split: 'watch?v=' | last | split: '&' | first %}
                    {% elsif video_url contains 'youtu.be/' %}
                      {% assign video_id = video_url | split: 'youtu.be/' | last | split: '?' | first %}
                    {% endif %}
                    <iframe
                      src="https://www.youtube.com/embed/{{ video_id }}"
                      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                      allowfullscreen
                    ></iframe>
                  {% elsif video_url contains 'vimeo.com' %}
                    {% assign video_id = video_url | split: 'vimeo.com/' | last | split: '/' | first %}
                    <iframe
                      src="https://player.vimeo.com/video/{{ video_id }}"
                      allow="autoplay; fullscreen; picture-in-picture"
                      allowfullscreen
                    ></iframe>
                  {% else %}
                    <video controls>
                      <source src="{{ video_url }}" type="video/mp4">
                    </video>
                  {% endif %}
                </div>
              {% elsif image != blank %}
                <img
                  src="{{ image | image_url: width: 1000 }}"
                  alt="{{ label | escape }}"
                  loading="lazy"
                  width="{{ image.width }}"
                  height="{{ image.height }}"
                >
              {% else %}
                <div class="boku-media-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>

            <div class="boku-mode-text-{{ ai_gen_id }}">
              {% if title != blank %}
                <h3>{{ title }}</h3>
              {% endif %}
              {% if description != blank %}
                <p>{{ description }}</p>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</boku-modes-block-{{ ai_gen_id }}>

<script>
  (function() {
    class BokuModesBlock{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.buttons = this.querySelectorAll('.boku-mode-button-{{ ai_gen_id }}');
        this.contents = this.querySelectorAll('.boku-mode-item-{{ ai_gen_id }}');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.buttons.forEach((button) => {
          button.addEventListener('click', () => {
            const modeIndex = button.getAttribute('data-mode-index');
            this.switchMode(modeIndex);
          });
        });
      }

      switchMode(modeIndex) {
        this.buttons.forEach((btn) => {
          if (btn.getAttribute('data-mode-index') === modeIndex) {
            btn.classList.add('active');
          } else {
            btn.classList.remove('active');
          }
        });

        this.contents.forEach((content) => {
          if (content.getAttribute('data-mode-content') === modeIndex) {
            content.classList.add('active');
          } else {
            content.classList.remove('active');
          }
        });
      }
    }

    customElements.define('boku-modes-block-{{ ai_gen_id }}', BokuModesBlock{{ ai_gen_id }});
  })();
</script>

